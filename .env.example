# Frontend Environment Variables

# API URL for the backend server
# For local development:
# VITE_API_URL=http://localhost:5000
# For EC2 deployment (replace with your actual EC2 public IP or domain):
# VITE_API_URL=http://your-ec2-ip:5000
# VITE_API_URL=https://api.yourdomain.com

VITE_API_URL=http://localhost:5000

# Google Apps Script webhook URL for interest form submissions
# Create one at: script.google.com → New Project → Deploy as Web App
VITE_INTEREST_FORM_WEBHOOK_URL=
